__pycache__/


# macOS specific files
.DS_Store

# Linux specific files
*~

# IDE specific files
.vscode/
.idea/

# User dotfiles (accidentally in repo root)
.bash_profile
.bashrc
.profile
.zprofile
.zshrc
.gitconfig
.ripgreprc
.mcp.json

# Virtual environment directories
venv/
env/
.env/

# Byte-compiled / optimized / DLL files
__pycache__/
*.pyc
*.pyo
*.pyd

# Shared objects (except our LD_PRELOAD library)
*.so
!lib/*.so

# Coverage/Test files
.coverage
.tox/
htmlcov/
.pytest_cache/

# Log files and checkpoints
*.log
*.err
*.out
logs/*

# Binary directory
bin/

# Monitoring secrets
monitoring/.env
monitoring/alertmanager/alertmanager-local.yml

# Operational runtime secrets / deploy-generated files (never committed)
config/runtime/teams-webhook-url.txt
config/deploy/sudoers.d/ds01-deploy

# Per-user data — retained only in the full/downstream repo, not the org repo.
# This list is the single source of truth: sync-downstream.sh force-adds
# whatever is git-ignored under config/runtime/ into the downstream mirror.
/config/runtime/groups/*.members
/config/runtime/group-overrides.txt
/config/runtime/user-overrides.yaml
/config/runtime/lifecycle-exemptions.yaml
