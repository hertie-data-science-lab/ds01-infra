#!/usr/bin/env bash
# prod-git-guard: post-checkout is advisory only — it fires AFTER the working
# tree has already been switched, so it cannot veto (that is exactly the #93
# footgun, and only the Phase 2 detached prod prevents it structurally). Warn
# loudly if the PRODUCTION checkout has been moved off main. Never fails.
#
# Args: $1 = previous HEAD, $2 = new HEAD, $3 = branch-checkout flag (1/0).

if [ "$(git rev-parse --show-toplevel 2>/dev/null)" = "/opt/ds01-infra" ] && [ "${3:-0}" = "1" ]; then
    branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null)"
    if [ "$branch" != "main" ]; then
        {
            echo ""
            echo "  ###################################################################"
            echo "  # prod-git-guard WARNING: /opt/ds01-infra is now on '$branch'."
            echo "  # The live runtime executes from this checkout. Restore main now:"
            echo "  #     git -C /opt/ds01-infra checkout main"
            echo "  ###################################################################"
            echo ""
        } >&2
    fi
fi

DS01_HOOK_NAME=post-checkout exec "$(dirname "$0")/chain" "$@"
