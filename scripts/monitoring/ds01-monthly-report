def _load_previous_summary(year: int, month: int) -> dict[str, float | int] | None:
    """Load previous month's summary JSON sidecar."""
    if month == 1:
        prev_year, prev_month = year - 1, 12
    else:
        prev_year, prev_month = year, month - 1
    path = REPORTS_DIR / f"{prev_year}-{prev_month:02d}-summary.json"
    try:
        data = json.loads(path.read_text())
        return data.get("metrics", {})
    except (OSError, json.JSONDecodeError):
        return None


def _trend_str(current: float, previous: float, is_pct: bool = False) -> str:
    """Format a trend indicator: '15 (+3)' or '42.3% (-2.1pp)'."""
    delta = current - previous
    if previous != 0:
        pct_change = abs(delta / previous) * 100
    else:
        pct_change = 0

    if delta > 0:
        arrow = "\u2191"
    elif delta < 0:
        arrow = "\u2193"
    else:
        arrow = "\u2192"

    if is_pct:
        return f"{current:.1f}% ({arrow} {abs(delta):.1f}pp)"
    elif abs(current) >= 100:
        return f"{current:,.0f} ({arrow} {pct_change:.0f}%)"
    else:
        return f"{int(current)} ({arrow} {abs(int(delta))})"


def _section_trends(
    year: int,
    month: int,
    summary_data: dict[str, float | int | None],
) -> tuple[list[str], dict[str, str]]:
    lines: list[str] = []
    summary: dict[str, str] = {}

    prev = _load_previous_summary(year, month)
    if prev is None:
        lines.append("*Previous month's data not available. Trends will appear from next month.*")
        return lines, summary

    if month == 1:
        prev_month_name = calendar.month_name[12]
    else:
        prev_month_name = calendar.month_name[month - 1]
    lines.append(f"Compared to {prev_month_name}:\n")

    trend_keys = [
        ("active_gpu_users", "Active GPU users", False),
        ("total_gpu_hours", "Total GPU-hours", False),
        ("gpu_efficiency", "GPU efficiency", True),
        ("avg_cpu_pct", "Average CPU utilisation", True),
        ("total_members", "Total members", False),
        ("new_users", "New users", False),
        ("containers_created", "Containers created", False),
        ("gpu_rejected", "GPU requests rejected", False),
        ("issues_opened", "Issues opened", False),
        ("issues_closed", "Issues closed", False),
    ]

    for key, label, is_pct in trend_keys:
        curr = summary_data.get(key)
        prev_val = prev.get(key)
        if curr is not None and prev_val is not None:
            lines.append(f"- **{label}:** {_trend_str(float(curr), float(prev_val), is_pct)}")

    return lines, summary


def generate_report(
    year: int, month: int
) -> tuple[str, dict[str, str], dict[str, float | int | None]]:
    """Generate the full monthly report as Markdown.

    Returns (report_md, summary_display, summary_data):
    - report_md: full markdown report string
    - summary_display: formatted strings for Teams card
    - summary_data: numeric values for JSON sidecar + trends
    """
    days_in_month = calendar.monthrange(year, month)[1]
    month_name = calendar.month_name[month]
    generated_at = datetime.now(timezone.utc).strftime("%Y-%m-%d %H:%M UTC")

    # Time boundaries
    month_start = f"{year}-{month:02d}-01"
    month_end = f"{year}-{month:02d}-{days_in_month:02d}"
    query_time = f"{year}-{month:02d}-{days_in_month:02d}T23:59:59Z"
    range_str = f"{days_in_month}d"

    # Timestamps for event log queries
    start_ts = datetime(year, month, 1, tzinfo=timezone.utc).timestamp()
    if month == 12:
        end_ts = datetime(year + 1, 1, 1, tzinfo=timezone.utc).timestamp()
    else:
        end_ts = datetime(year, month + 1, 1, tzinfo=timezone.utc).timestamp()

    # Load group membership
    groups = load_group_membership()

    # Single-pass event log scan for all needed event types
    container_event_types = {
        "container.create",
        "detection.container_discovered",
        "detection.container_exited",
        "gpu.rejected",
        "auth.denied",
        "bare_metal.warning",
    }
    event_types_needed = {"user.added"} | set(LIFECYCLE_EVENT_TYPES.keys()) | container_event_types
    container_events: dict[str, list[dict]] = {t: [] for t in container_event_types}
    event_counts = count_events_in_range(start_ts, end_ts, event_types_needed, container_events)

    # Query user-group mapping once for table lookups
    # Index by both full (user@domain) and short (user) forms for cross-metric matching
    user_group_map: dict[str, str] = {}
    # Query current group membership (not at report time — metric may not have existed then)
    for r in prom_query("ds01_user_group_info"):
        m = r.get("metric", {})
        user = m.get("user", "")
        group = m.get("group", "")
        user_group_map[user] = group
        if "@" in user:
            user_group_map[user.split("@")[0]] = group

    lines: list[str] = []
    summary: dict[str, str] = {}

    # Header
    lines.append(f"# DS01 Monthly Report -- {month_name} {year}")
    lines.append("")
    lines.append(f"**Period:** {month_start} to {month_end}")
    lines.append(f"**Generated:** {generated_at}")
    lines.append("")
    lines.append("---")

    # Sections (all data-gathering sections first)
    sections: list[tuple[str, tuple[list[str], dict[str, str]]]] = [
        (
            "User Activity",
            _section_user_activity(
                query_time, range_str, month_start, month_end, groups, event_counts
            ),
        ),
        (
            "GPU Resource Usage",
            _section_gpu_usage(query_time, range_str, user_group_map),
        ),
        (
            "CPU Resource Usage",
            _section_cpu_usage(query_time, range_str, user_group_map),
        ),
        (
            "Memory Usage",
            _section_memory_usage(query_time, range_str, user_group_map),
        ),
        (
            "Container Activity",
            _section_container_activity(container_events),
        ),
        (
            "System Load & Capacity",
            _section_system_load(query_time, range_str, month_start, month_end, event_counts),
        ),
        ("Support Tickets", _section_support_tickets(month_start, month_end)),
    ]

    for title, (section_lines, section_summary) in sections:
        lines.append(f"\n## {title}\n")
        lines.extend(section_lines)
        summary.update(section_summary)

    # Build summary_data (numeric values for JSON sidecar + trends)
    summary_data: dict[str, float | int | None] = {}

    def _parse_num(key: str) -> float | None:
        val = summary.get(key)
        if val is None:
            return None
        try:
            return float(val.replace(",", "").replace("%", ""))
        except ValueError:
            return None

    summary_data["active_gpu_users"] = _parse_num("Active GPU users")
    summary_data["total_gpu_hours"] = _parse_num("Total GPU-hours (allocated)")
    summary_data["gpu_efficiency"] = _parse_num("GPU efficiency")
    summary_data["avg_cpu_pct"] = _parse_num("Average system CPU utilisation")
    summary_data["avg_memory_pct"] = _parse_num("Average memory utilisation")
    summary_data["total_members"] = sum(len(m) for m in groups.values())
    summary_data["members_by_group"] = {g: len(m) for g, m in groups.items()}
    summary_data["new_users"] = event_counts.get("user.added", 0)
    summary_data["containers_created"] = len(container_events.get("container.create", []))
    summary_data["gpu_rejected"] = len(container_events.get("gpu.rejected", []))

    # Parse ticket counts from summary
    summary_data["issues_opened"] = _parse_num("Issues opened")
    summary_data["issues_closed"] = _parse_num("Issues closed")

    # Trends section (computed after all others)
    trends_lines, trends_summary = _section_trends(year, month, summary_data)
    lines.append("\n## Month-over-Month Trends\n")
    lines.extend(trends_lines)
    summary.update(trends_summary)

    # Footer
    lines.append("\n---")
    lines.append(f"\n*Generated by ds01-monthly-report on {generated_at}*")

    return "\n".join(lines) + "\n", summary, summary_data


