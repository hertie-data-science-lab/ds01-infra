GRAFANA_BASE_URL = os.environ.get("GRAFANA_URL", "http://localhost:3000")


def build_teams_summary(
    summary: dict[str, str],
    summary_data: dict[str, float | int | None],
    year: int,
    month: int,
) -> str:
    """Build a rich Teams Adaptive Card with headline KPIs, facts, and highlights."""
    month_name = calendar.month_name[month]
    # Grafana link with month time range
    start_epoch_ms = int(datetime(year, month, 1, tzinfo=timezone.utc).timestamp() * 1000)
    if month == 12:
        end_epoch_ms = int(datetime(year + 1, 1, 1, tzinfo=timezone.utc).timestamp() * 1000)
    else:
        end_epoch_ms = int(datetime(year, month + 1, 1, tzinfo=timezone.utc).timestamp() * 1000)
    grafana_url = f"{GRAFANA_BASE_URL}/d/ds01-monthly/?from={start_epoch_ms}&to={end_epoch_ms}"

    # Load previous month for trend arrows
    prev = _load_previous_summary(year, month)

    def _val(key: str) -> str:
        """Get display value from summary dict."""
        return summary.get(key, "-")

    def _trend(key: str, is_pct: bool = False) -> str:
        """Get value with trend arrow if previous data exists."""
        curr = summary_data.get(key)
        if curr is None:
            return _val(key) if not is_pct else "-"
        if prev and key in prev and prev[key] is not None:
            return _trend_str(float(curr), float(prev[key]), is_pct)
        if is_pct:
            return f"{curr:.1f}%"
        return f"{int(curr)}" if curr == int(curr) else f"{curr:,.1f}"

    # Headline KPI columns
    kpi_columns = [
        ("Active Users", _trend("active_gpu_users")),
        ("GPU-Hours", summary.get("Total GPU-hours (allocated)", "-")),
        ("GPU Efficiency", _trend("gpu_efficiency", is_pct=True)),
    ]
    columns = []
    for label, value in kpi_columns:
        columns.append(
            {
                "type": "Column",
                "width": "stretch",
                "items": [
                    {"type": "TextBlock", "text": label, "size": "Small", "isSubtle": True},
                    {
                        "type": "TextBlock",
                        "text": str(value),
                        "size": "ExtraLarge",
                        "weight": "Bolder",
                        "color": "Accent",
                    },
                ],
            }
        )

    # Fact set — key metrics with trends
    facts = []
    cpu_val = _trend("avg_cpu_pct", is_pct=True)
    if cpu_val != "-":
        facts.append({"title": "CPU utilisation", "value": cpu_val})
    mem_val = _trend("avg_memory_pct", is_pct=True)
    if mem_val != "-":
        facts.append({"title": "Memory utilisation", "value": mem_val})
    avg_temp = summary.get("Avg GPU temp", "")
    peak_temp = summary.get("Peak GPU temp", "")
    if avg_temp or peak_temp:
        facts.append({"title": "GPU temperature", "value": f"{avg_temp} avg / {peak_temp} peak"})
    containers_val = _trend("containers_created")
    if containers_val != "-":
        facts.append({"title": "Containers created", "value": containers_val})
    gpu_rej_val = _trend("gpu_rejected")
    if gpu_rej_val != "-" and summary_data.get("gpu_rejected", 0):
        facts.append({"title": "GPU rejected", "value": gpu_rej_val})
    issues_opened = _trend("issues_opened")
    issues_closed = _trend("issues_closed")
    if issues_opened != "-" or issues_closed != "-":
        facts.append(
            {"title": "Issues", "value": f"{issues_opened} opened / {issues_closed} closed"}
        )
    res_mean = summary.get("Resolution mean", "")
    res_median = summary.get("Resolution median", "")
    if res_mean or res_median:
        facts.append(
            {"title": "Resolution time", "value": f"{res_mean} mean / {res_median} median"}
        )

    # Users by group
    new_users_val = _trend("new_users")
    total_members = summary_data.get("total_members", 0)
    members_by_group = summary_data.get("members_by_group", {})
    if new_users_val != "-" or total_members:
        group_parts = [
            f"{g}: {c}"
            for g, c in sorted(members_by_group.items(), key=lambda x: x[1], reverse=True)
            if g != "archived"
        ]
        facts.append(
            {"title": "Users", "value": f"{new_users_val} new / {int(total_members or 0)} total"}
        )
        if group_parts:
            facts.append({"title": "By group", "value": ", ".join(group_parts)})

    # Highlights
    highlights = []
    busiest = summary.get("Busiest period")
    if busiest:
        highlights.append(f"- Busiest: {busiest}")
    new_users_count = summary_data.get("new_users", 0) or 0
    if new_users_count > 0:
        highlights.append(f"- {int(new_users_count)} new user(s) joined")
    if prev:
        gpu_curr = summary_data.get("total_gpu_hours")
        gpu_prev = prev.get("total_gpu_hours")
        if gpu_curr and gpu_prev and gpu_prev > 0:
            pct = ((gpu_curr - gpu_prev) / gpu_prev) * 100
            direction = "up" if pct > 0 else "down"
            prev_name = calendar.month_name[12 if month == 1 else month - 1]
            highlights.append(f"- GPU usage {direction} {abs(pct):.0f}% vs {prev_name}")

    # Build card body
    body: list[dict] = [
        {
            "type": "TextBlock",
            "text": f"DS01 Monthly Report \u2014 {month_name} {year}",
            "weight": "Bolder",
            "size": "Large",
        },
        {"type": "ColumnSet", "columns": columns},
    ]
    if facts:
        body.append({"type": "FactSet", "facts": facts})
    if highlights:
        body.append({"type": "TextBlock", "text": "**Highlights**", "spacing": "Medium"})
        body.append(
            {"type": "TextBlock", "text": "\n".join(highlights), "wrap": True, "size": "Small"}
        )

    # Grafana link (internal for now)
    body.append(
        {
            "type": "ActionSet",
            "actions": [
                {
                    "type": "Action.OpenUrl",
                    "title": "View in Grafana (internal)",
                    "url": grafana_url,
                }
            ],
        }
    )
    body.append(
        {
            "type": "TextBlock",
            "text": (
                "Full report posted below. "
                "Grafana dashboard and email delivery coming soon "
                "\u2014 external access via Cloudflare tunnel planned."
            ),
            "size": "Small",
            "isSubtle": True,
            "spacing": "Small",
        }
    )

    card = {
        "type": "message",
        "attachments": [
            {
                "contentType": "application/vnd.microsoft.card.adaptive",
                "contentVersion": "1.4",
                "content": {
                    "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
                    "type": "AdaptiveCard",
                    "version": "1.4",
                    "body": body,
                },
            }
        ],
    }
    return json.dumps(card)


def _post_webhook(url: str, payload: str, label: str = "Teams") -> bool:
    """Post a JSON payload to a webhook URL."""
    try:
        req = urllib.request.Request(
            url,
            data=payload.encode("utf-8"),
            headers={"Content-Type": "application/json"},
            method="POST",
        )
        with urllib.request.urlopen(req, timeout=15) as resp:
            return resp.status in (200, 202)
    except (urllib.error.URLError, OSError) as e:
        print(f"  {label} post failed: {e}", file=sys.stderr)
        return False


def post_to_teams(summary_card: str, report_md: str | None = None) -> bool:
    """Post summary card to Teams, optionally followed by full report as second message."""
    url = _load_teams_webhook_url()
    if not url:
        print("  Teams webhook URL not configured -- skipping", file=sys.stderr)
        return False

    ok = _post_webhook(url, summary_card, "Teams summary card")
    if ok and report_md:
        # Post full report as a simple text message (Teams renders basic markdown)
        text_payload = json.dumps({"text": report_md})
        _post_webhook(url, text_payload, "Teams full report")
    return ok


# ============================================================================
# Main
# ============================================================================


def main() -> None:
    parser = argparse.ArgumentParser(description="DS01 Monthly Report Generator")
    parser.add_argument(
        "--month",
        help="Month to report on (YYYY-MM). Defaults to previous month.",
    )
    parser.add_argument(
        "--dry-run",
        action="store_true",
        help="Print report to stdout without saving or posting.",
    )
    parser.add_argument(
        "--no-teams",
        action="store_true",
        help="Save report but don't post to Teams.",
    )
    args = parser.parse_args()

    # Determine target month
    if args.month:
        try:
            parts = args.month.split("-")
            year, month = int(parts[0]), int(parts[1])
            if not (1 <= month <= 12):
                raise ValueError
        except (ValueError, IndexError):
            print(f"Invalid month format: {args.month} (expected YYYY-MM)")
            sys.exit(1)
    else:
        # Previous month
        now = datetime.now(timezone.utc)
        if now.month == 1:
            year, month = now.year - 1, 12
        else:
            year, month = now.year, now.month - 1

    month_name = calendar.month_name[month]
    print(f"Generating report for {month_name} {year}...")

    # Generate
    report, summary, summary_data = generate_report(year, month)

    if args.dry_run:
        print(report)
        return

    # Save report markdown
    REPORTS_DIR.mkdir(parents=True, exist_ok=True)
    report_file = REPORTS_DIR / f"{year}-{month:02d}.md"
    report_file.write_text(report)
    latest_link = REPORTS_DIR / "_latest.md"
    latest_link.unlink(missing_ok=True)
    latest_link.symlink_to(report_file.name)
    print(f"Report saved: {report_file}")

    # Save JSON sidecar for month-over-month trends
    sidecar = {
        "version": 1,
        "year": year,
        "month": month,
        "generated_at": datetime.now(timezone.utc).isoformat(),
        "metrics": {k: v for k, v in summary_data.items() if v is not None},
    }
    sidecar_file = REPORTS_DIR / f"{year}-{month:02d}-summary.json"
    sidecar_file.write_text(json.dumps(sidecar, indent=2) + "\n")
    print(f"Summary saved: {sidecar_file}")

    # Post to Teams (summary card + full report as second message)
    if not args.no_teams:
        print("Posting to Teams...")
        card_payload = build_teams_summary(summary, summary_data, year, month)
        if post_to_teams(card_payload, report):
            print("Teams notification sent.")
        else:
            print("Teams notification skipped or failed.")

    print("Done.")


if __name__ == "__main__":
    main()
