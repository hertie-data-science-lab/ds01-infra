def display_user(user: str) -> str:
    """Strip domain for table display."""
    return user.split("@")[0] if "@" in user else user


def _lookup_group(user: str, user_group_map: dict[str, str]) -> str:
    """Look up user's group, trying both full and short username forms."""
    group = user_group_map.get(user)
    if group:
        return group
    # Try stripping domain (GPU metrics may have @domain, group_info may not, or vice versa)
    short = user.split("@")[0] if "@" in user else user
    return user_group_map.get(short, "-")


def _render_user_table(
    title: str, unit: str, data: dict[str, float], user_group_map: dict[str, str]
) -> list[str]:
    """Render a top-15 user table with group lookup."""
    lines = [f"\n### {title}\n"]
    lines.append(f"| User | Group | {unit} |")
    lines.append("|------|-------|-----------|")
    for user, hours in sorted(data.items(), key=lambda x: x[1], reverse=True):
        group = _lookup_group(user, user_group_map)
        lines.append(f"| {display_user(user)} | {group} | {hours:,.1f} |")
    return lines


def _section_user_activity(
    query_time: str,
    range_str: str,
    month_start: str,
    month_end: str,
    groups: dict[str, list[str]],
    event_counts: dict[str, int],
) -> tuple[list[str], dict[str, str]]:
    lines: list[str] = []
    summary: dict[str, str] = {}

    total_members = sum(len(m) for m in groups.values())

    # Active GPU users (distinct users with allocations during the month)
    gpu_users = prom_vector(
        f"count by (user)(count_over_time(ds01_gpu_allocated[{range_str}]))",
        query_time,
    )
    active_gpu_users = len(gpu_users)

    # Peak concurrent GPU users
    peak_users = prom_scalar(f"max_over_time(ds01:system_active_users[{range_str}])", query_time)

    # SSH users (distinct users with sessions during the month)
    ssh_range = prom_query_range(
        "ds01_ssh_sessions_active",
        f"{month_start}T00:00:00Z",
        f"{month_end}T23:59:59Z",
        "15m",
    )
    ssh_users = set()
    for series in ssh_range:
        user = series.get("metric", {}).get("user", "")
        if user:
            for _, val in series.get("values", []):
                if float(val) > 0:
                    ssh_users.add(user)
                    break

    lines.append(f"- **Total registered users:** {total_members}")
    lines.append(f"- **Active GPU users:** {active_gpu_users}")
    summary["Active GPU users"] = str(active_gpu_users)
    if peak_users is not None:
        lines.append(f"- **Peak concurrent GPU users:** {int(peak_users)}")
    lines.append(f"- **Unique SSH users:** {len(ssh_users)}")

    # By group
    lines.append("\n### By Group\n")

    # Count distinct active GPU users per group (using current group mapping)
    gpu_by_group = prom_vector(
        f"count by (group)("
        f"count by (user, group)("
        f"count_over_time(ds01_gpu_allocated[{range_str}])"
        f") * on(user) group_left(group) ds01_user_group_info"
        f")",
        query_time,
    )

    lines.append("| Group | Members | Active (GPU) |")
    lines.append("|-------|---------|--------------|")
    for group in ("student", "researcher", "faculty", "admin"):
        member_count = len(groups.get(group, []))
        active = int(gpu_by_group.get(group, 0))
        lines.append(f"| {group} | {member_count} | {active} |")

    # User growth
    new_users = event_counts.get("user.added", 0)
    if new_users > 0:
        lines.append(f"\n**New users this month:** {new_users}")
    else:
        lines.append("\n*User growth tracking enabled -- data available from next sync cycle.*")

    return lines, summary


def _section_gpu_usage(
    query_time: str,
    range_str: str,
    user_group_map: dict[str, str],
) -> tuple[list[str], dict[str, str]]:
    lines: list[str] = []
    summary: dict[str, str] = {}

    # Total GPU-hours (count_over_time * scrape_interval is accurate for gauges;
    # increase() on the recording rule gauge gives wrong results)
    total_gpu_hours = prom_scalar(
        f"sum(count_over_time(ds01_gpu_allocated[{range_str}])) * 30 / 3600", query_time
    )
    weighted_gpu_hours = prom_scalar(
        f"sum(sum_over_time(ds01:user_gpu_seconds_weighted[{range_str}])) / 3600",
        query_time,
    )

    if total_gpu_hours is not None:
        lines.append(f"- **Total GPU-hours (allocated):** {total_gpu_hours:,.1f}")
        summary["Total GPU-hours (allocated)"] = f"{total_gpu_hours:,.1f}"
    if weighted_gpu_hours is not None:
        lines.append(f"- **Total GPU-hours (utilisation-weighted):** {weighted_gpu_hours:,.1f}")
    if total_gpu_hours and weighted_gpu_hours and total_gpu_hours > 1:
        efficiency = (weighted_gpu_hours / total_gpu_hours) * 100
        lines.append(f"- **GPU efficiency:** {efficiency:.1f}%")
        summary["GPU efficiency"] = f"{efficiency:.1f}%"

    # Average waste
    avg_waste = prom_scalar(f"avg_over_time(ds01:gpu_waste_percent[{range_str}])", query_time)
    if avg_waste is not None and not math.isnan(avg_waste):
        lines.append(f"- **Average GPU waste:** {avg_waste:.1f}%")

    # Per-user GPU-hours (allocated + weighted, top 15 by allocated)
    user_alloc = prom_query(
        f"topk(15, sum by (user)(count_over_time(ds01_gpu_allocated[{range_str}])) * 30 / 3600)",
        query_time,
    )
    user_weighted = prom_vector(
        f"topk(15, sum_over_time(ds01:user_gpu_seconds_weighted[{range_str}]) / 3600)",
        query_time,
    )
    if user_alloc:
        lines.append("\n### GPU-Hours by User (Top 15)\n")
        lines.append("| User | Group | Allocated | Weighted |")
        lines.append("|------|-------|-----------|----------|")
        for r in user_alloc:
            user = r.get("metric", {}).get("user", "?")
            group = _lookup_group(user, user_group_map)
            try:
                alloc_h = float(r["value"][1])
            except (KeyError, ValueError, IndexError):
                continue
            weight_h = user_weighted.get(user, 0)
            lines.append(f"| {display_user(user)} | {group} | {alloc_h:,.1f} | {weight_h:,.1f} |")

    # Per-container GPU-hours (top 15)
    # 30s multiplier = ds01-exporter scrape interval
    container_results = prom_query(
        f"topk(15, sum by (container, user)"
        f"(count_over_time(ds01_gpu_allocated[{range_str}])) * 30 / 3600)",
        query_time,
    )
    # Per-container weighted: allocated_hours * avg_utilisation of each slot
    container_weighted = {}
    weighted_results = prom_query(
        f"sum by (container, user)("
        f"count_over_time(ds01_gpu_allocated[{range_str}]) * 30 / 3600"
        f" * on(gpu_slot) group_left()"
        f" (avg_over_time(ds01:gpu_utilization_by_slot[{range_str}]) / 100))",
        query_time,
    )
    for r in weighted_results:
        m = r.get("metric", {})
        key = (m.get("container", ""), m.get("user", ""))
        try:
            container_weighted[key] = float(r["value"][1])
        except (KeyError, ValueError, IndexError):
            pass

    if container_results:
        lines.append("\n### GPU-Hours by Container (Top 15)\n")
        lines.append("| Container | User | Group | Allocated | Weighted |")
        lines.append("|-----------|------|-------|-----------|----------|")
        for r in container_results:
            m = r.get("metric", {})
            container = m.get("container", "?")
            user = m.get("user", "?")
            group = _lookup_group(user, user_group_map)
            try:
                hours = float(r["value"][1])
            except (KeyError, ValueError, IndexError):
                continue
            w_hours = container_weighted.get((container, user), 0)
            lines.append(
                f"| {container} | {display_user(user)} | {group} | {hours:,.1f} | {w_hours:,.1f} |"
            )

    return lines, summary


def _section_cpu_usage(
    query_time: str,
    range_str: str,
    user_group_map: dict[str, str],
) -> tuple[list[str], dict[str, str]]:
    lines: list[str] = []
    summary: dict[str, str] = {}

    # System CPU
    avg_cpu = prom_scalar(
        f"100 - (avg_over_time("
        f'(avg(rate(node_cpu_seconds_total{{mode="idle"}}[5m])) * 100)'
        f"[{range_str}:1h]))",
        query_time,
    )
    peak_cpu = prom_scalar(
        f"100 - (min_over_time("
        f'(avg(rate(node_cpu_seconds_total{{mode="idle"}}[5m])) * 100)'
        f"[{range_str}:1h]))",
        query_time,
    )

    if avg_cpu is not None:
        lines.append(f"- **Average system CPU utilisation:** {avg_cpu:.1f}%")
        summary["Average system CPU utilisation"] = f"{avg_cpu:.1f}%"
    if peak_cpu is not None:
        lines.append(f"- **Peak system CPU utilisation:** {peak_cpu:.1f}%")

    # Per-user CPU-hours (counter — use increase over the month; if the metric
    # has less history than range_str, fall back to the raw counter value)
    user_cpu_hours = prom_vector(
        f"topk(15, increase(ds01_user_cpu_usage_seconds_total[{range_str}]) / 3600)",
        query_time,
    )
    if not user_cpu_hours:
        user_cpu_hours = prom_vector(
            "topk(15, ds01_user_cpu_usage_seconds_total / 3600)",
            query_time,
        )
    if user_cpu_hours:
        lines.extend(
            _render_user_table(
                "CPU-Hours by User (Top 15)", "CPU-Hours", user_cpu_hours, user_group_map
            )
        )
    else:
        lines.append(
            "*Per-user CPU data not available for this period (insufficient metric history).*"
        )

    return lines, summary


def _section_memory_usage(
    query_time: str,
    range_str: str,
    user_group_map: dict[str, str],
) -> tuple[list[str], dict[str, str]]:
    lines: list[str] = []
    summary: dict[str, str] = {}

    # System memory
    total_bytes = prom_scalar("node_memory_MemTotal_bytes", query_time)
    avg_used_pct = prom_scalar(
        f"100 - (avg_over_time("
        f"(node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes * 100)"
        f"[{range_str}:1h]))",
        query_time,
    )
    peak_used_pct = prom_scalar(
        f"100 - (min_over_time("
        f"(node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes * 100)"
        f"[{range_str}:1h]))",
        query_time,
    )

    if total_bytes is not None:
        lines.append(f"- **Total system memory:** {total_bytes / (1024**3):,.1f} GiB")
    if avg_used_pct is not None:
        lines.append(f"- **Average memory utilisation:** {avg_used_pct:.1f}%")
        summary["Average memory utilisation"] = f"{avg_used_pct:.1f}%"
    if peak_used_pct is not None:
        lines.append(f"- **Peak memory utilisation:** {peak_used_pct:.1f}%")

    # Per-user memory (top 15 by average during active periods)
    user_mem = prom_vector(
        f"topk(15, avg_over_time(ds01_user_memory_current_bytes[{range_str}]) / (1024*1024*1024))",
        query_time,
    )
    if user_mem:
        lines.extend(
            _render_user_table("Memory by User (Top 15)", "Avg GiB", user_mem, user_group_map)
        )
    else:
        lines.append(
            "*Per-user memory data not available for this period (insufficient metric history).*"
        )

    return lines, summary


def _section_container_activity(
    container_events: dict[str, list[dict]],
) -> tuple[list[str], dict[str, str]]:
    lines: list[str] = []
    summary: dict[str, str] = {}

    creates = container_events.get("container.create", [])
    discovered = container_events.get("detection.container_discovered", [])
    exited = container_events.get("detection.container_exited", [])
    rejected = container_events.get("gpu.rejected", [])
    denied = container_events.get("auth.denied", [])
    bare_metal = container_events.get("bare_metal.warning", [])

    total_created = len(creates)
    total_exited = len(exited)
    lines.append(f"- **Containers created:** {total_created}")
    lines.append(f"- **Containers exited:** {total_exited}")
    summary["Containers created"] = str(total_created)

    # Container type breakdown (from container.create events)
    if creates:
        by_type: dict[str, int] = defaultdict(int)
        for ev in creates:
            ctype = ev.get("container_type", "unknown")
            by_type[ctype] += 1
        type_parts = [
            f"{t}: {c}" for t, c in sorted(by_type.items(), key=lambda x: x[1], reverse=True)
        ]
        lines.append(f"- **By type:** {', '.join(type_parts)}")

    # GPU vs non-GPU ratio (from detection.container_discovered)
    if discovered:
        gpu_count = sum(1 for ev in discovered if ev.get("has_gpu"))
        non_gpu = len(discovered) - gpu_count
        lines.append(f"- **GPU containers:** {gpu_count} | **Non-GPU:** {non_gpu}")

    # Per-user container creation counts (top 10)
    if creates:
        by_user: dict[str, int] = defaultdict(int)
        for ev in creates:
            by_user[ev.get("user", "unknown")] += 1

        lines.append("\n### Containers Created by User (Top 10)\n")
        lines.append("| User | Containers |")
        lines.append("|------|------------|")
        for user, count in sorted(by_user.items(), key=lambda x: x[1], reverse=True)[:10]:
            lines.append(f"| {display_user(user)} | {count} |")

    # Average container lifetime (match discovered/exited by container_id)
    discover_times: dict[str, float] = {}
    for ev in discovered:
        cid = ev.get("container_id", "")
        if cid:
            discover_times[cid] = ev.get("ts", 0)

    lifetimes: list[float] = []
    for ev in exited:
        cid = ev.get("container_id", "")
        if cid in discover_times:
            lifetime_h = (ev.get("ts", 0) - discover_times[cid]) / 3600
            if lifetime_h >= 0:
                lifetimes.append(lifetime_h)

    if lifetimes:
        avg_lifetime = sum(lifetimes) / len(lifetimes)
        sorted_lt = sorted(lifetimes)
        median_lifetime = sorted_lt[len(sorted_lt) // 2]
        lines.append(
            f"\n- **Average container lifetime:** {avg_lifetime:.1f}h (n={len(lifetimes)})"
        )
        lines.append(f"- **Median container lifetime:** {median_lifetime:.1f}h")

    # GPU rejections, auth denied, bare metal warnings — with top offenders
    def _top_users(events: list[dict], n: int = 5) -> str:
        by_user: dict[str, int] = defaultdict(int)
        for ev in events:
            by_user[display_user(ev.get("user", "unknown"))] += 1
        top = sorted(by_user.items(), key=lambda x: x[1], reverse=True)[:n]
        return ", ".join(f"{u} ({c})" for u, c in top)

    if rejected:
        summary["GPU rejected"] = str(len(rejected))
        lines.append(f"\n- **GPU requests rejected:** {len(rejected)}")
        lines.append(f"  - Top users: {_top_users(rejected)}")
    if denied:
        lines.append(f"- **Auth denied (bare metal GPU):** {len(denied)}")
        lines.append(f"  - Top users: {_top_users(denied)}")
    if bare_metal:
        lines.append(f"- **Bare metal GPU warnings:** {len(bare_metal)}")
        lines.append(f"  - Top users: {_top_users(bare_metal)}")

    return lines, summary


def _section_system_load(
    query_time: str,
    range_str: str,
    month_start: str,
    month_end: str,
    event_counts: dict[str, int],
) -> tuple[list[str], dict[str, str]]:
    lines: list[str] = []
    summary: dict[str, str] = {}

    lines.append("\n### GPU Capacity\n")

    total_gpus = prom_scalar("ds01:system_full_gpu_slots_total")
    avg_allocated = prom_scalar(
        f"avg_over_time(ds01:system_full_gpu_slots_allocated[{range_str}])", query_time
    )
    peak_allocated = prom_scalar(
        f"max_over_time(ds01:system_full_gpu_slots_allocated[{range_str}])", query_time
    )
    avg_free = prom_scalar(
        f"avg_over_time(ds01:system_full_gpu_slots_free[{range_str}])", query_time
    )

    if total_gpus is not None:
        lines.append(f"- **Total GPUs:** {int(total_gpus)}")
    if avg_allocated is not None:
        lines.append(f"- **Average allocated:** {avg_allocated:.1f}")
    if peak_allocated is not None:
        lines.append(f"- **Peak allocated:** {int(peak_allocated)}")
    if avg_free is not None:
        lines.append(f"- **Average free:** {avg_free:.1f}")

    # Peak usage patterns
    lines.append("\n### Usage Patterns\n")

    day_names = ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"]
    hourly_data = prom_query_range(
        "ds01:hourly_mig_allocated_avg",
        f"{month_start}T00:00:00Z",
        f"{month_end}T23:59:59Z",
        "1h",
    )

    if hourly_data:
        # Build weekday x 3-hour-block grid for heatmap
        grid: dict[int, dict[int, list[float]]] = {d: {b: [] for b in range(8)} for d in range(7)}
        # Also track per-slot averages for busiest/quietest
        slot_avgs: dict[str, list[float]] = {}

        for series in hourly_data:
            for ts_str, val_str in series.get("values", []):
                try:
                    ts = datetime.fromtimestamp(float(ts_str), tz=timezone.utc)
                    val = float(val_str)
                    grid[ts.weekday()][ts.hour // 3].append(val)
                    key = f"{day_names[ts.weekday()]} {ts.hour:02d}:00"
                    slot_avgs.setdefault(key, []).append(val)
                except (ValueError, IndexError):
                    continue

        # Render weekday x time-of-day heatmap
        block_labels = ["00-03", "03-06", "06-09", "09-12", "12-15", "15-18", "18-21", "21-00"]
        heatmap_lines = ["             " + "  ".join(f"{b:>5s}" for b in block_labels)]
        chars = ["\u2591", "\u2592", "\u2593", "\u2588"]
        for day_idx in range(7):
            cells = []
            for block_idx in range(8):
                vals = grid[day_idx][block_idx]
                avg = sum(vals) / len(vals) if vals else 0
                if avg >= 3:
                    ch = chars[3]
                elif avg >= 2:
                    ch = chars[2]
                elif avg >= 1:
                    ch = chars[1]
                else:
                    ch = chars[0]
                cells.append(f"  {ch * 3}  ")
            heatmap_lines.append(f"{day_names[day_idx]:>11s}  {''.join(cells)}")
        heatmap_lines.append("")
        heatmap_lines.append(
            f"{chars[0]} <1 slot  {chars[1]} 1-2 slots  {chars[2]} 2-3 slots  {chars[3]} 3+ slots"
        )

        lines.append("**GPU Slot Allocation by Day/Time (avg)**\n")
        lines.append("```text")
        lines.extend(heatmap_lines)
        lines.append("```")

        # Busiest / quietest
        if slot_avgs:
            avg_by_slot = {k: sum(v) / len(v) for k, v in slot_avgs.items()}
            busiest = max(avg_by_slot, key=avg_by_slot.get)
            quietest = min(avg_by_slot, key=avg_by_slot.get)
            lines.append(
                f"\n- **Busiest period:** {busiest} (avg {avg_by_slot[busiest]:.1f} slots)"
            )
            lines.append(
                f"- **Quietest period:** {quietest} (avg {avg_by_slot[quietest]:.1f} slots)"
            )
            summary["Busiest period"] = f"{busiest} (avg {avg_by_slot[busiest]:.1f} slots)"

    # Daily GPU-hours bar chart
    daily_data = prom_query_range(
        "sum(increase(ds01:user_gpu_seconds[1d])) / 3600",
        f"{month_start}T00:00:00Z",
        f"{month_end}T23:59:59Z",
        "1d",
    )
    if daily_data:
        daily_hours: list[tuple[str, float]] = []
        for series in daily_data:
            for ts_str, val_str in series.get("values", []):
                try:
                    ts = datetime.fromtimestamp(float(ts_str), tz=timezone.utc)
                    val = round(max(0, float(val_str)), 1)
                    daily_hours.append((ts.strftime("%b %d"), val))
                except (ValueError, IndexError):
                    continue

        if daily_hours:
            max_hours = max(h for _, h in daily_hours) or 1
            bar_width = 30
            peak_day = max(daily_hours, key=lambda x: x[1])
            chart_lines = []
            block_full = "\u2588"
            block_light = "\u2591"
            for label, hours in daily_hours:
                filled = int((hours / max_hours) * bar_width)
                empty = bar_width - filled
                suffix = "  <- peak" if hours == peak_day[1] and hours > 0 else ""
                bar = block_full * filled + block_light * empty
                chart_lines.append(f"{label}  {bar}  {hours:,.1f}h{suffix}")

            lines.append("\n**GPU-Hours by Day**\n")
            lines.append("```text")
            lines.extend(chart_lines)
            lines.append("```")

    # Temperature & health
    lines.append("\n### Temperature & Health\n")

    avg_temp = prom_scalar(f"avg_over_time(ds01:system_gpu_temp_avg[{range_str}])", query_time)
    peak_temp = prom_scalar(f"max_over_time(ds01:system_gpu_temp_max[{range_str}])", query_time)

    if avg_temp is not None:
        lines.append(f"- **Average GPU temperature:** {avg_temp:.0f}\u00b0C")
        summary["Avg GPU temp"] = f"{avg_temp:.0f}\u00b0C"
    if peak_temp is not None:
        lines.append(f"- **Peak GPU temperature:** {peak_temp:.0f}\u00b0C")
        summary["Peak GPU temp"] = f"{peak_temp:.0f}\u00b0C"

    # Lifecycle events from event log (already scanned above)
    lifecycle = {
        LIFECYCLE_EVENT_TYPES[k]: v for k, v in event_counts.items() if k in LIFECYCLE_EVENT_TYPES
    }
    if lifecycle:
        event_parts = [f"{k}: {v}" for k, v in sorted(lifecycle.items())]
        lines.append(f"- **Lifecycle events:** {', '.join(event_parts)}")
    else:
        lines.append("- **Lifecycle events:** none")

    return lines, summary


