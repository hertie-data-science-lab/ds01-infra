def build_teams_summary(summary: dict[str, str], year: int, month: int) -> str:
    """Build a Teams Adaptive Card from structured summary metrics."""
    month_name = calendar.month_name[month]

    summary_parts = []
    for key in [
        "Active GPU users",
        "Total GPU-hours (allocated)",
        "GPU efficiency",
        "Average system CPU utilisation",
        "Issues opened",
    ]:
        if key in summary:
            summary_parts.append(f"{key}: {summary[key]}")

    summary_text = " | ".join(summary_parts) if summary_parts else "Report generated"

    card = {
        "type": "message",
        "attachments": [
            {
                "contentType": "application/vnd.microsoft.card.adaptive",
                "contentVersion": "1.4",
                "content": {
                    "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
                    "type": "AdaptiveCard",
                    "version": "1.4",
                    "body": [
                        {
                            "type": "TextBlock",
                            "text": f"DS01 Monthly Report -- {month_name} {year}",
                            "weight": "Bolder",
                            "size": "Medium",
                        },
                        {
                            "type": "TextBlock",
                            "text": summary_text,
                            "wrap": True,
                        },
                        {
                            "type": "TextBlock",
                            "text": (
                                f"Full report: "
                                f"/var/log/ds01-infra/reports/monthly/"
                                f"{year}-{month:02d}.md"
                            ),
                            "size": "Small",
                            "isSubtle": True,
                        },
                    ],
                },
            }
        ],
    }
    return json.dumps(card)


def post_to_teams(payload: str) -> bool:
    """Post an Adaptive Card payload to Teams via webhook."""
    url = _load_teams_webhook_url()
    if not url:
        print("  Teams webhook URL not configured -- skipping", file=sys.stderr)
        return False

    try:
        req = urllib.request.Request(
            url,
            data=payload.encode("utf-8"),
            headers={"Content-Type": "application/json"},
            method="POST",
        )
        with urllib.request.urlopen(req, timeout=15) as resp:
            return resp.status in (200, 202)
    except (urllib.error.URLError, OSError) as e:
        print(f"  Teams post failed: {e}", file=sys.stderr)
        return False


# ============================================================================
# Main
# ============================================================================


def main() -> None:
    parser = argparse.ArgumentParser(description="DS01 Monthly Report Generator")
    parser.add_argument(
        "--month",
        help="Month to report on (YYYY-MM). Defaults to previous month.",
    )
    parser.add_argument(
        "--dry-run",
        action="store_true",
        help="Print report to stdout without saving or posting.",
    )
    parser.add_argument(
        "--no-teams",
        action="store_true",
        help="Save report but don't post to Teams.",
    )
    args = parser.parse_args()

    # Determine target month
    if args.month:
        try:
            parts = args.month.split("-")
            year, month = int(parts[0]), int(parts[1])
            if not (1 <= month <= 12):
                raise ValueError
        except (ValueError, IndexError):
            print(f"Invalid month format: {args.month} (expected YYYY-MM)")
            sys.exit(1)
    else:
        # Previous month
        now = datetime.now(timezone.utc)
        if now.month == 1:
            year, month = now.year - 1, 12
        else:
            year, month = now.year, now.month - 1

    month_name = calendar.month_name[month]
    print(f"Generating report for {month_name} {year}...")

    # Generate
    report, summary = generate_report(year, month)

    if args.dry_run:
        print(report)
        return

    # Save to file
    REPORTS_DIR.mkdir(parents=True, exist_ok=True)
    report_file = REPORTS_DIR / f"{year}-{month:02d}.md"
    report_file.write_text(report)
    latest_link = REPORTS_DIR / "_latest.md"
    latest_link.unlink(missing_ok=True)
    latest_link.symlink_to(report_file.name)
    print(f"Report saved: {report_file}")

    # Post to Teams
    if not args.no_teams:
        print("Posting summary to Teams...")
        payload = build_teams_summary(summary, year, month)
        if post_to_teams(payload):
            print("Teams notification sent.")
        else:
            print("Teams notification skipped or failed.")

    print("Done.")


if __name__ == "__main__":
    main()
