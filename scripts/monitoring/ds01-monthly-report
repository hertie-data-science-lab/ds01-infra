#!/usr/bin/env python3
"""
DS01 Monthly Report Generator

Queries Prometheus, GitHub Issues, group membership files, and the event log
to produce a monthly summary report. Optionally posts a summary to Teams.

Usage:
    ds01-monthly-report                    # Previous month, save + post
    ds01-monthly-report --month 2026-03    # Specific month
    ds01-monthly-report --dry-run          # Print to stdout only
    ds01-monthly-report --no-teams         # Save but don't post
"""

import argparse
import calendar
import gzip
import json
import math
import os
import subprocess
import sys
import urllib.error
import urllib.request
from collections import defaultdict
from datetime import datetime, timezone
from pathlib import Path
from typing import Any

# ============================================================================
# Configuration
# ============================================================================

PROMETHEUS_URL = "http://localhost:9090"
INFRA_ROOT = Path("/opt/ds01-infra")
GROUPS_DIR = INFRA_ROOT / "config/runtime/groups"
EVENTS_FILE = Path("/var/log/ds01/events.jsonl")
REPORTS_DIR = Path("/var/log/ds01-infra/reports/monthly")
GITHUB_REPO = "hertie-data-science-lab/ds01-hub"


def _load_teams_webhook_url() -> str | None:
    """Load Teams webhook URL from environment or config file."""
    url = os.environ.get("DS01_TEAMS_WEBHOOK_URL")
    if url:
        return url

    try:
        text = (INFRA_ROOT / "config/runtime/teams-webhook-url.txt").read_text().strip()
        if text and not text.startswith("PLACEHOLDER"):
            return text
    except OSError:
        pass

    return None


# ============================================================================
# Prometheus Client
# ============================================================================


def _prom_request(path: str, params: str, timeout: int = 30) -> list[dict]:
    """Shared Prometheus HTTP request: build URL, fetch, parse result vector."""
    url = f"{PROMETHEUS_URL}{path}?{params}"
    try:
        with urllib.request.urlopen(url, timeout=timeout) as resp:
            data = json.loads(resp.read())
            if data.get("status") == "success":
                return data["data"]["result"]
    except (urllib.error.URLError, json.JSONDecodeError, KeyError, OSError) as e:
        print(f"  [warn] Prometheus query failed: {e}", file=sys.stderr)
    return []


def prom_query(expr: str, time: str | None = None) -> list[dict]:
    """Execute an instant query against Prometheus."""
    params = f"query={urllib.request.quote(expr)}"
    if time:
        params += f"&time={urllib.request.quote(time)}"
    return _prom_request("/api/v1/query", params)


def prom_query_range(expr: str, start: str, end: str, step: str = "1h") -> list[dict]:
    """Execute a range query against Prometheus."""
    params = (
        f"query={urllib.request.quote(expr)}"
        f"&start={urllib.request.quote(start)}"
        f"&end={urllib.request.quote(end)}"
        f"&step={urllib.request.quote(step)}"
    )
    return _prom_request("/api/v1/query_range", params, timeout=60)


def prom_scalar(expr: str, time: str | None = None) -> float | None:
    """Get a single scalar value from Prometheus."""
    results = prom_query(expr, time)
    if results:
        try:
            return float(results[0]["value"][1])
        except (IndexError, KeyError, ValueError):
            pass
    return None


def prom_vector(expr: str, time: str | None = None) -> dict[str, float]:
    """Get a label->value mapping from Prometheus."""
    results = prom_query(expr, time)
    out: dict[str, float] = {}
    for r in results:
        # Use the first non-__name__ label as key, or "user" if present
        metric = r.get("metric", {})
        key = metric.get("user") or metric.get("group") or str(metric)
        try:
            out[key] = float(r["value"][1])
        except (KeyError, ValueError):
            pass
    return out


