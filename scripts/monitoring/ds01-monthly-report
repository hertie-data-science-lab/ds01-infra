}


def count_events_in_range(
    start_ts: float,
    end_ts: float,
    match_types: set[str],
    container_events: dict[str, list[dict]] | None = None,
) -> dict[str, int]:
    """Single-pass event log scan: count events by type within a time range.

    Scans events.jsonl and rotated archives once, counting all matching event types.
    When container_events is provided, also collects structured event dicts for those types.
    """
    counts: dict[str, int] = {}
    files: list[Path] = []

    # Collect all event log files
    events_dir = EVENTS_FILE.parent
    for gz_file in sorted(events_dir.glob("events.jsonl-*.gz")):
        files.append(gz_file)
    # Also non-gzipped rotated files
    for f in sorted(events_dir.glob("events.jsonl-*[0-9]")):
        files.append(f)
    if EVENTS_FILE.exists():
        files.append(EVENTS_FILE)

    collect_types = set(container_events.keys()) if container_events else set()

    for f in files:
        try:
            opener = gzip.open(f, "rt") if f.suffix == ".gz" else open(f)
            with opener as fh:
                for line in fh:
                    try:
                        event = json.loads(line.strip())
                        etype = event.get("event_type", "")
                        if etype not in match_types:
                            continue
                        ts_str = event.get("timestamp", "")
                        if ts_str:
                            ts = datetime.fromisoformat(ts_str.replace("Z", "+00:00"))
                            if start_ts <= ts.timestamp() <= end_ts:
                                counts[etype] = counts.get(etype, 0) + 1
                                if etype in collect_types:
                                    entry = {
                                        "user": event.get("user", "unknown"),
                                        "ts": ts.timestamp(),
                                    }
                                    entry.update(event.get("details", {}))
                                    container_events[etype].append(entry)
                    except (json.JSONDecodeError, ValueError):
                        continue
        except OSError:
            continue

    return counts


def query_github_issues(month_start: str, month_end: str) -> dict[str, Any] | None:
    """Query GitHub Issues for the given month via gh CLI.

    Args:
        month_start: ISO date string (e.g., "2026-03-01")
        month_end: ISO date string (e.g., "2026-03-31")

    Returns dict with keys: opened, closed, resolution_days_mean, resolution_days_median, by_label, or None on failure.
    """
    try:
        # Use --search with date qualifiers to scope server-side, avoiding the
        # default behaviour of fetching the 500 most-recently-updated issues
        # across all time (which silently misses data in repos with >500 issues).
        # Run as datasciencelab user to inherit gh CLI auth (cron runs as root)
        cmd = [
            "gh",
            "issue",
            "list",
            "--repo",
            GITHUB_REPO,
            "--state",
            "all",
            "--json",
            "number,title,state,createdAt,closedAt,labels",
            "--limit",
            "500",
            "--search",
            f"created:{month_start}..{month_end} updated:{month_start}..{month_end}",
        ]
        # If running as root, use sudo to inherit datasciencelab's gh auth
        if getpass.getuser() == "root":
            cmd = ["sudo", "-u", "datasciencelab"] + cmd
        result = subprocess.run(cmd, capture_output=True, text=True, timeout=30)
        if result.returncode != 0:
            print(f"  [warn] gh issue list failed: {result.stderr.strip()}", file=sys.stderr)
            return None

        issues = json.loads(result.stdout)
    except (subprocess.TimeoutExpired, FileNotFoundError, json.JSONDecodeError) as e:
        print(f"  [warn] GitHub Issues query failed: {e}", file=sys.stderr)
        return None

    start_dt = datetime.fromisoformat(f"{month_start}T00:00:00+00:00")
    end_dt = datetime.fromisoformat(f"{month_end}T23:59:59+00:00")

    opened = 0
    closed = 0
    resolution_times: list[float] = []
    by_label: dict[str, dict[str, int]] = defaultdict(lambda: {"opened": 0, "closed": 0})

    for issue in issues:
        created_str = issue.get("createdAt", "")
        closed_str = issue.get("closedAt")

        try:
            created = datetime.fromisoformat(created_str.replace("Z", "+00:00"))
        except (ValueError, AttributeError):
            continue

        # Count opened in month
        if start_dt <= created <= end_dt:
            opened += 1
            for label in issue.get("labels", []):
                by_label[label.get("name", "unlabelled")]["opened"] += 1

        # Count closed in month
        if closed_str:
            try:
                closed_dt = datetime.fromisoformat(closed_str.replace("Z", "+00:00"))
                if start_dt <= closed_dt <= end_dt:
                    closed += 1
                    for label in issue.get("labels", []):
                        by_label[label.get("name", "unlabelled")]["closed"] += 1

                    # Resolution time
                    delta = (closed_dt - created).total_seconds() / 86400
                    if delta >= 0:
                        resolution_times.append(delta)
            except (ValueError, AttributeError):
                pass

    avg_resolution = sum(resolution_times) / len(resolution_times) if resolution_times else None
    if resolution_times:
        sorted_rt = sorted(resolution_times)
        median_resolution = sorted_rt[len(sorted_rt) // 2]
    else:
        median_resolution = None

    return {
        "opened": opened,
        "closed": closed,
        "resolution_days_mean": avg_resolution,
        "resolution_days_median": median_resolution,
        "by_label": dict(by_label),
    }


