def load_group_membership() -> dict[str, list[str]]:
    """Load group membership from .members files.

    Returns dict of group -> list of usernames.
    """
    groups: dict[str, list[str]] = {}
    for members_file in sorted(GROUPS_DIR.glob("*.members")):
        group = members_file.stem
        if group == "archived":
            continue
        members: list[str] = []
        try:
            for line in members_file.read_text().splitlines():
                line = line.split("#")[0].strip()
                if line:
                    members.append(line)
        except OSError:
            continue
        groups[group] = members
    return groups


# Lifecycle event types to track in monthly reports
LIFECYCLE_EVENT_TYPES = {
    "maintenance.idle_kill": "idle_kill",
    "maintenance.runtime_kill": "runtime_kill",
    "resource.oom_kill": "oom_kill",
}


def count_events_in_range(start_ts: float, end_ts: float, match_types: set[str]) -> dict[str, int]:
    """Single-pass event log scan: count events by type within a time range.

    Scans events.jsonl and rotated archives once, counting all matching event types.
    """
    counts: dict[str, int] = {}
    files: list[Path] = []

    # Collect all event log files
    events_dir = EVENTS_FILE.parent
    for gz_file in sorted(events_dir.glob("events.jsonl-*.gz")):
        files.append(gz_file)
    # Also non-gzipped rotated files
    for f in sorted(events_dir.glob("events.jsonl-*[0-9]")):
        files.append(f)
    if EVENTS_FILE.exists():
        files.append(EVENTS_FILE)

    for f in files:
        try:
            opener = gzip.open(f, "rt") if f.suffix == ".gz" else open(f)
            with opener as fh:
                for line in fh:
                    try:
                        event = json.loads(line.strip())
                        etype = event.get("event_type", "")
                        if etype not in match_types:
                            continue
                        ts_str = event.get("timestamp", "")
                        if ts_str:
                            ts = datetime.fromisoformat(ts_str.replace("Z", "+00:00"))
                            if start_ts <= ts.timestamp() <= end_ts:
                                counts[etype] = counts.get(etype, 0) + 1
                    except (json.JSONDecodeError, ValueError):
                        continue
        except OSError:
            continue

    return counts


def query_github_issues(month_start: str, month_end: str) -> dict[str, Any] | None:
    """Query GitHub Issues for the given month via gh CLI.

    Args:
        month_start: ISO date string (e.g., "2026-03-01")
        month_end: ISO date string (e.g., "2026-03-31")

    Returns dict with keys: opened, closed, resolution_days, by_label, or None on failure.
    """
    try:
        # Use --search with date qualifiers to scope server-side, avoiding the
        # default behaviour of fetching the 500 most-recently-updated issues
        # across all time (which silently misses data in repos with >500 issues).
        result = subprocess.run(
            [
                "gh",
                "issue",
                "list",
                "--repo",
                GITHUB_REPO,
                "--state",
                "all",
                "--json",
                "number,title,state,createdAt,closedAt,labels",
                "--limit",
                "500",
                "--search",
                f"created:{month_start}..{month_end} updated:{month_start}..{month_end}",
            ],
            capture_output=True,
            text=True,
            timeout=30,
        )
        if result.returncode != 0:
            print(f"  [warn] gh issue list failed: {result.stderr.strip()}", file=sys.stderr)
            return None

        issues = json.loads(result.stdout)
    except (subprocess.TimeoutExpired, FileNotFoundError, json.JSONDecodeError) as e:
        print(f"  [warn] GitHub Issues query failed: {e}", file=sys.stderr)
        return None

    start_dt = datetime.fromisoformat(f"{month_start}T00:00:00+00:00")
    end_dt = datetime.fromisoformat(f"{month_end}T23:59:59+00:00")

    opened = 0
    closed = 0
    resolution_times: list[float] = []
    by_label: dict[str, dict[str, int]] = defaultdict(lambda: {"opened": 0, "closed": 0})

    for issue in issues:
        created_str = issue.get("createdAt", "")
        closed_str = issue.get("closedAt")

        try:
            created = datetime.fromisoformat(created_str.replace("Z", "+00:00"))
        except (ValueError, AttributeError):
            continue

        # Count opened in month
        if start_dt <= created <= end_dt:
            opened += 1
            for label in issue.get("labels", []):
                by_label[label.get("name", "unlabelled")]["opened"] += 1

        # Count closed in month
        if closed_str:
            try:
                closed_dt = datetime.fromisoformat(closed_str.replace("Z", "+00:00"))
                if start_dt <= closed_dt <= end_dt:
                    closed += 1
                    for label in issue.get("labels", []):
                        by_label[label.get("name", "unlabelled")]["closed"] += 1

                    # Resolution time
                    delta = (closed_dt - created).total_seconds() / 86400
                    if delta >= 0:
                        resolution_times.append(delta)
            except (ValueError, AttributeError):
                pass

    avg_resolution = sum(resolution_times) / len(resolution_times) if resolution_times else None

    return {
        "opened": opened,
        "closed": closed,
        "resolution_days": avg_resolution,
        "by_label": dict(by_label),
    }


# ============================================================================
# Report Generation
# ============================================================================


def display_user(user: str) -> str:
    """Strip domain for table display."""
    return user.split("@")[0] if "@" in user else user


def _render_user_table(
    title: str, unit: str, data: dict[str, float], user_group_map: dict[str, str]
) -> list[str]:
    """Render a top-15 user table with group lookup."""
    lines = [f"\n### {title}\n"]
    lines.append(f"| User | Group | {unit} |")
    lines.append("|------|-------|-----------|")
    for user, hours in sorted(data.items(), key=lambda x: x[1], reverse=True):
        group = user_group_map.get(user, "-")
        lines.append(f"| {display_user(user)} | {group} | {hours:,.1f} |")
    return lines


def _section_user_activity(
    query_time: str,
    range_str: str,
    month_start: str,
    month_end: str,
    groups: dict[str, list[str]],
    event_counts: dict[str, int],
) -> tuple[list[str], dict[str, str]]:
    lines: list[str] = []
    summary: dict[str, str] = {}

    total_members = sum(len(m) for m in groups.values())

    # Active GPU users (distinct users with allocations during the month)
    gpu_users = prom_vector(
        f"count by (user)(count_over_time(ds01_gpu_allocated[{range_str}]))",
        query_time,
    )
    active_gpu_users = len(gpu_users)

    # Peak concurrent GPU users
    peak_users = prom_scalar(f"max_over_time(ds01:system_active_users[{range_str}])", query_time)

    # SSH users (distinct users with sessions during the month)
    ssh_range = prom_query_range(
        "ds01_ssh_sessions_active",
        f"{month_start}T00:00:00Z",
        f"{month_end}T23:59:59Z",
        "15m",
    )
    ssh_users = set()
    for series in ssh_range:
        user = series.get("metric", {}).get("user", "")
        if user:
            for _, val in series.get("values", []):
                if float(val) > 0:
                    ssh_users.add(user)
                    break

    lines.append(f"- **Total registered users:** {total_members}")
    lines.append(f"- **Active GPU users:** {active_gpu_users}")
    summary["Active GPU users"] = str(active_gpu_users)
    if peak_users is not None:
        lines.append(f"- **Peak concurrent GPU users:** {int(peak_users)}")
    lines.append(f"- **Unique SSH users:** {len(ssh_users)}")

    # By group
    lines.append("\n### By Group\n")

    # Count distinct active GPU users per group (using current group mapping)
    gpu_by_group = prom_vector(
        f"count by (group)("
        f"count by (user, group)("
        f"count_over_time(ds01_gpu_allocated[{range_str}])"
        f") * on(user) group_left(group) ds01_user_group_info"
        f")",
        query_time,
    )

    lines.append("| Group | Members | Active (GPU) |")
    lines.append("|-------|---------|--------------|")
    for group in ("student", "researcher", "faculty", "admin"):
        member_count = len(groups.get(group, []))
        active = int(gpu_by_group.get(group, 0))
        lines.append(f"| {group} | {member_count} | {active} |")

    # User growth
    new_users = event_counts.get("user.added", 0)
    if new_users > 0:
        lines.append(f"\n**New users this month:** {new_users}")
    else:
        lines.append("\n*User growth tracking enabled -- data available from next sync cycle.*")

    return lines, summary


def _section_gpu_usage(
    query_time: str,
    range_str: str,
    user_group_map: dict[str, str],
) -> tuple[list[str], dict[str, str]]:
    lines: list[str] = []
    summary: dict[str, str] = {}

    # Total GPU-hours
    total_gpu_hours = prom_scalar(
        f"sum(increase(ds01:user_gpu_seconds[{range_str}])) / 3600", query_time
    )
    weighted_gpu_hours = prom_scalar(
        f"sum(increase(ds01:user_gpu_seconds_weighted[{range_str}])) / 3600",
        query_time,
    )

    if total_gpu_hours is not None:
        lines.append(f"- **Total GPU-hours (allocated):** {total_gpu_hours:,.1f}")
        summary["Total GPU-hours (allocated)"] = f"{total_gpu_hours:,.1f}"
    if weighted_gpu_hours is not None:
        lines.append(f"- **Total GPU-hours (utilisation-weighted):** {weighted_gpu_hours:,.1f}")
    if total_gpu_hours and weighted_gpu_hours and total_gpu_hours > 1:
        efficiency = (weighted_gpu_hours / total_gpu_hours) * 100
        lines.append(f"- **GPU efficiency:** {efficiency:.1f}%")
        summary["GPU efficiency"] = f"{efficiency:.1f}%"

    # Average waste
    avg_waste = prom_scalar(f"avg_over_time(ds01:gpu_waste_percent[{range_str}])", query_time)
    if avg_waste is not None and not math.isnan(avg_waste):
        lines.append(f"- **Average GPU waste:** {avg_waste:.1f}%")

    # Per-user GPU-hours (top 15)
    user_gpu_hours = prom_vector(
        f"topk(15, increase(ds01:user_gpu_seconds[{range_str}]) / 3600)",
        query_time,
    )
    if user_gpu_hours:
        lines.extend(
            _render_user_table(
                "GPU-Hours by User (Top 15)", "GPU-Hours", user_gpu_hours, user_group_map
            )
        )

    return lines, summary


def _section_cpu_usage(
    query_time: str,
    range_str: str,
    user_group_map: dict[str, str],
) -> tuple[list[str], dict[str, str]]:
    lines: list[str] = []
    summary: dict[str, str] = {}

    # System CPU
    avg_cpu = prom_scalar(
        f"100 - (avg_over_time("
        f'(avg(rate(node_cpu_seconds_total{{mode="idle"}}[5m])) * 100)'
        f"[{range_str}:1h]))",
        query_time,
    )
    peak_cpu = prom_scalar(
        f"100 - (min_over_time("
        f'(avg(rate(node_cpu_seconds_total{{mode="idle"}}[5m])) * 100)'
        f"[{range_str}:1h]))",
        query_time,
    )

    if avg_cpu is not None:
        lines.append(f"- **Average system CPU utilisation:** {avg_cpu:.1f}%")
        summary["Average system CPU utilisation"] = f"{avg_cpu:.1f}%"
    if peak_cpu is not None:
        lines.append(f"- **Peak system CPU utilisation:** {peak_cpu:.1f}%")

    # Per-user CPU-hours (counter — use increase over the month, fall back to
    # current value if the metric has less than a full month of history)
    user_cpu_hours = prom_vector(
        f"topk(15, (increase(ds01_user_cpu_usage_seconds_total[{range_str}])"
        f" or ds01_user_cpu_usage_seconds_total) / 3600)",
        query_time,
    )
    if user_cpu_hours:
        lines.extend(
            _render_user_table(
                "CPU-Hours by User (Top 15)", "CPU-Hours", user_cpu_hours, user_group_map
            )
        )
    else:
        lines.append("*Per-user CPU data not yet available (requires ds01-exporter v2.3.0+).*")

    return lines, summary


def _section_system_load(
    query_time: str,
    range_str: str,
    month_start: str,
    month_end: str,
    event_counts: dict[str, int],
) -> tuple[list[str], dict[str, str]]:
    lines: list[str] = []
    summary: dict[str, str] = {}

    lines.append("\n### GPU Capacity\n")

    avg_allocated = prom_scalar(
        f"avg_over_time(ds01:system_mig_allocated[{range_str}])", query_time
    )
    peak_allocated = prom_scalar(
        f"max_over_time(ds01:system_mig_allocated[{range_str}])", query_time
    )
    avg_free = prom_scalar(f"avg_over_time(ds01:system_mig_free[{range_str}])", query_time)
    total_slots = prom_scalar("ds01:system_mig_total", query_time)

    if total_slots is not None:
        lines.append(f"- **Total GPU/MIG slots:** {int(total_slots)}")
    if avg_allocated is not None:
        lines.append(f"- **Average allocated:** {avg_allocated:.1f}")
    if peak_allocated is not None:
        lines.append(f"- **Peak allocated:** {int(peak_allocated)}")
    if avg_free is not None:
        lines.append(f"- **Average free:** {avg_free:.1f}")

    # Peak usage patterns
    lines.append("\n### Peak Usage Patterns\n")

    hourly_data = prom_query_range(
        "ds01:hourly_mig_allocated_avg",
        f"{month_start}T00:00:00Z",
        f"{month_end}T23:59:59Z",
        "1h",
    )

    if hourly_data:
        hourly_buckets: dict[str, list[float]] = {}
        day_names = [
            "Monday",
            "Tuesday",
            "Wednesday",
            "Thursday",
            "Friday",
            "Saturday",
            "Sunday",
        ]

        for series in hourly_data:
            for ts_str, val_str in series.get("values", []):
                try:
                    ts = datetime.fromtimestamp(float(ts_str), tz=timezone.utc)
                    val = float(val_str)
                    key = f"{day_names[ts.weekday()]} {ts.hour:02d}:00"
                    if key not in hourly_buckets:
                        hourly_buckets[key] = []
                    hourly_buckets[key].append(val)
                except (ValueError, IndexError):
                    continue

        if hourly_buckets:
            avg_by_slot = {k: sum(v) / len(v) for k, v in hourly_buckets.items()}
            busiest = max(avg_by_slot, key=avg_by_slot.get)
            quietest = min(avg_by_slot, key=avg_by_slot.get)
            lines.append(f"- **Busiest period:** {busiest} (avg {avg_by_slot[busiest]:.1f} slots)")
            lines.append(
                f"- **Quietest period:** {quietest} (avg {avg_by_slot[quietest]:.1f} slots)"
            )

    # Temperature & health
    lines.append("\n### Temperature & Health\n")

    avg_temp = prom_scalar(f"avg_over_time(ds01:system_gpu_temp_avg[{range_str}])", query_time)
    peak_temp = prom_scalar(f"max_over_time(ds01:system_gpu_temp_max[{range_str}])", query_time)

    if avg_temp is not None:
        lines.append(f"- **Average GPU temperature:** {avg_temp:.0f}\u00b0C")
    if peak_temp is not None:
        lines.append(f"- **Peak GPU temperature:** {peak_temp:.0f}\u00b0C")

    # Lifecycle events from event log (already scanned above)
    lifecycle = {
        LIFECYCLE_EVENT_TYPES[k]: v for k, v in event_counts.items() if k in LIFECYCLE_EVENT_TYPES
    }
    if lifecycle:
        event_parts = [f"{k}: {v}" for k, v in sorted(lifecycle.items())]
        lines.append(f"- **Lifecycle events:** {', '.join(event_parts)}")
    else:
        lines.append("- **Lifecycle events:** none")

    return lines, summary


def _section_support_tickets(
    month_start: str,
    month_end: str,
) -> tuple[list[str], dict[str, str]]:
    lines: list[str] = []
    summary: dict[str, str] = {}

    tickets = query_github_issues(month_start, month_end)
    if tickets:
        lines.append(f"- **Issues opened:** {tickets['opened']}")
        summary["Issues opened"] = str(tickets["opened"])
        lines.append(f"- **Issues closed:** {tickets['closed']}")
        if tickets["resolution_days"] is not None:
            lines.append(f"- **Average resolution time:** {tickets['resolution_days']:.1f} days")

        if tickets["by_label"]:
            lines.append("\n### By Category\n")
            lines.append("| Category | Opened | Closed |")
            lines.append("|----------|--------|--------|")
            for label, counts in sorted(
                tickets["by_label"].items(),
                key=lambda x: x[1]["opened"],
                reverse=True,
            ):
                lines.append(f"| {label} | {counts['opened']} | {counts['closed']} |")
    else:
        lines.append("*GitHub Issues data not available (ensure `gh` CLI is authenticated).*")

    return lines, summary


def generate_report(year: int, month: int) -> tuple[str, dict[str, str]]:
    """Generate the full monthly report as Markdown.

    Returns (report_text, summary_metrics) where summary_metrics is a dict
    of key metric names to display values for the Teams card.
    """
    days_in_month = calendar.monthrange(year, month)[1]
    month_name = calendar.month_name[month]
    generated_at = datetime.now(timezone.utc).strftime("%Y-%m-%d %H:%M UTC")

    # Time boundaries
    month_start = f"{year}-{month:02d}-01"
    month_end = f"{year}-{month:02d}-{days_in_month:02d}"
    query_time = f"{year}-{month:02d}-{days_in_month:02d}T23:59:59Z"
    range_str = f"{days_in_month}d"

    # Timestamps for event log queries
    start_ts = datetime(year, month, 1, tzinfo=timezone.utc).timestamp()
    if month == 12:
        end_ts = datetime(year + 1, 1, 1, tzinfo=timezone.utc).timestamp()
    else:
        end_ts = datetime(year, month + 1, 1, tzinfo=timezone.utc).timestamp()

    # Load group membership
    groups = load_group_membership()

    # Single-pass event log scan for all needed event types
    event_types_needed = {"user.added"} | set(LIFECYCLE_EVENT_TYPES.keys())
    event_counts = count_events_in_range(start_ts, end_ts, event_types_needed)

    # Query user-group mapping once for table lookups
    user_group_map: dict[str, str] = {}
    for r in prom_query("ds01_user_group_info", query_time):
        m = r.get("metric", {})
        user_group_map[m.get("user", "")] = m.get("group", "")

    lines: list[str] = []
    summary: dict[str, str] = {}

    # Header
    lines.append(f"# DS01 Monthly Report -- {month_name} {year}")
    lines.append("")
    lines.append(f"**Period:** {month_start} to {month_end}")
    lines.append(f"**Generated:** {generated_at}")
    lines.append("")
    lines.append("---")

    # Sections
    sections: list[tuple[str, tuple[list[str], dict[str, str]]]] = [
        (
            "User Activity",
            _section_user_activity(
                query_time, range_str, month_start, month_end, groups, event_counts
            ),
        ),
        (
            "GPU Resource Usage",
            _section_gpu_usage(query_time, range_str, user_group_map),
        ),
        (
            "CPU Resource Usage",
            _section_cpu_usage(query_time, range_str, user_group_map),
        ),
        (
            "System Load & Capacity",
            _section_system_load(query_time, range_str, month_start, month_end, event_counts),
        ),
        ("Support Tickets", _section_support_tickets(month_start, month_end)),
    ]

    for title, (section_lines, section_summary) in sections:
        lines.append(f"\n## {title}\n")
        lines.extend(section_lines)
        summary.update(section_summary)

    # Footer
    lines.append("\n---")
    lines.append(f"\n*Generated by ds01-monthly-report on {generated_at}*")

    return "\n".join(lines) + "\n", summary


