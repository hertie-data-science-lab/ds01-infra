def load_group_membership() -> dict[str, list[str]]:
    """Load group membership from .members files.

    Returns dict of group -> list of usernames.
    """
    groups: dict[str, list[str]] = {}
    for members_file in sorted(GROUPS_DIR.glob("*.members")):
        group = members_file.stem
        if group == "archived":
            continue
        members: list[str] = []
        try:
            for line in members_file.read_text().splitlines():
                line = line.split("#")[0].strip()
                if line:
                    members.append(line)
        except OSError:
            continue
        groups[group] = members
    return groups


